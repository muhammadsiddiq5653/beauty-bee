rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.uid == "Ltpv243kt0fmAWqg86neovZKiFB2";
    }

    // Products — public read, admin write
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Bundles — public read, admin write
    match /bundles/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders — anyone can create (customers), admin can read/update/delete
    match /orders/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Promo codes — public read (checkout validation), admin write
    match /promoCodes/{id} {
      allow get: if isAdmin() || resource.data.active != false;
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // Store settings — public read (delivery charge etc.), admin write
    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /email_subscribers/{id} {
      allow create: if request.resource.data.email is string
        && request.resource.data.email.size() <= 254;
      allow read, update, delete: if isAdmin();
    }

    match /analytics_events/{id} {
      allow create: if request.resource.data.keys().hasOnly([
          "event",
          "path",
          "referrer",
          "payload",
          "userAgent",
          "createdAt"
        ])
        && request.resource.data.keys().hasAll(["event", "path", "referrer", "payload", "userAgent", "createdAt"])
        && request.resource.data.event is string
        && request.resource.data.event.size() <= 80
        && request.resource.data.path is string
        && request.resource.data.path.size() <= 180
        && request.resource.data.referrer is string
        && request.resource.data.referrer.size() <= 300
        && request.resource.data.payload is map
        && request.resource.data.payload.keys().size() <= 20
        && request.resource.data.userAgent is string
        && request.resource.data.userAgent.size() <= 300
        && request.resource.data.createdAt == request.time;
      allow read, update, delete: if isAdmin();
    }
  }
}
